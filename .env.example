# Black2 Clearing Protocol - 环境变量配置模板

# ============================================
# 服务器配置
# ============================================
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ============================================
# 数据库配置
# ============================================
DATABASE_URL=sqlite:///./black2.db

# ============================================
# GitHub 锚定配置
# ============================================
# GitHub Personal Access Token (需要 repo 权限)
# 生成地址: https://github.com/settings/tokens
ANCHOR_GITHUB_TOKEN=ghp_your_personal_access_token_here

# GitHub 仓库 URL (用于存储合约哈希)
# 格式: https://github.com/username/repo
ANCHOR_GITHUB_REPO_URL=https://github.com/yongchaoqiu111/black2

# GitHub 分支名称
ANCHOR_GITHUB_BRANCH=main

# ============================================
# JWT 认证配置
# ============================================
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# CORS 配置
# ============================================
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=INFO
LOG_FILE=./logs/black2.log

# ============================================
# 推荐系统配置
# ============================================
# 5级推荐佣金比例 (总计 11.5%)
REFERRAL_LEVEL_1=0.05   # 5%
REFERRAL_LEVEL_2=0.03   # 3%
REFERRAL_LEVEL_3=0.02   # 2%
REFERRAL_LEVEL_4=0.01   # 1%
REFERRAL_LEVEL_5=0.005  # 0.5%

# ============================================
# 信誉分配置
# ============================================
# 初始信誉分
INITIAL_REPUTATION_SCORE=100

# 信誉分阈值
MIN_REPUTATION_TO_PUBLISH=60

# 保证金比例映射
MARGIN_RATE_EXCELLENT=0.05   # >= 90 分: 5%
MARGIN_RATE_GOOD=0.10        # >= 80 分: 10%
MARGIN_RATE_FAIR=0.15        # >= 70 分: 15%
MARGIN_RATE_POOR=0.20        # >= 60 分: 20%

# ============================================
# 自动确认配置
# ============================================
AUTO_CONFIRM_MIN_HOURS=24
AUTO_CONFIRM_MAX_HOURS=168
AUTO_CONFIRM_DEFAULT_HOURS=72

# ============================================
# 文件存储配置
# ============================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=100

# ============================================
# 沙箱验证配置 (未来功能)
# ============================================
SANDBOX_ENABLED=false
SANDBOX_TIMEOUT_SECONDS=300

# ============================================
# 邮件通知配置 (可选)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@black2protocol.com

# ============================================
# 支付网关配置 (未来功能)
# ============================================
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ============================================
# 注意 (IMPORTANT)
# ============================================
# 1. 复制此文件为 .env 并填入实际值
# 2. 永远不要将 .env 文件提交到版本控制
# 3. 在生产环境中使用强密码和密钥
# 4. 定期轮换敏感凭证
